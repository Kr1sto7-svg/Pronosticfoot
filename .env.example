# Clés API (Vercel > Settings > Environment Variables)

# football-data.org — onglet Live + Buteurs (compétitions). Saison en cours, gratuit.
# Jeton : https://www.football-data.org/client/register
FOOTBALLDATA_TOKEN=

# API-Football — onglet Buteurs > "Sélection nationale" (effectifs + stats joueurs).
# Clé : https://www.api-football.com  (tier gratuit : 100 requêtes/jour, saisons limitées)
APIFOOTBALL_KEY=

# The Odds API — onglet Live > "Cotes & value" (cotes multi-bookmakers, comparaison au modèle).
# Clé : https://the-odds-api.com  (vérifie que ton plan/free tier couvre le football)
ODDS_API_KEY=
